<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Central shadow of book -->
    <path
        android:pathData="M 30,36 C 30,36 38,32 54,36 C 70,32 78,36 78,36 L 78,74 C 78,74 70,70 54,74 C 38,70 30,74 30,74 Z"
        android:fillColor="#1A000000" />

    <!-- Open book pages (Left Page) - Blue Grad -->
    <path
        android:pathData="M 32,34 C 32,34 40,30 54,34 L 54,72 C 40,68 32,72 32,72 Z"
        android:fillType="nonZero">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="32"
                android:startY="34"
                android:endX="54"
                android:endY="72"
                android:type="linear">
                <item android:offset="0" android:color="#60a5fa" />
                <item android:offset="1" android:color="#2563eb" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Open book pages (Right Page) - Royal Blue Grad -->
    <path
        android:pathData="M 54,34 C 54,34 68,30 76,34 L 76,72 C 68,68 54,72 54,72 Z"
        android:fillType="nonZero">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="34"
                android:endX="76"
                android:endY="72"
                android:type="linear">
                <item android:offset="0" android:color="#3b82f6" />
                <item android:offset="1" android:color="#1d4ed8" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bookmark - Crimson Accent -->
    <path
        android:pathData="M 52,34 L 56,34 L 56,64 L 54,61 L 52,64 Z"
        android:fillColor="#ef4444" />

    <!-- Academic Star (Achievement Symbol) - Vibrant Gold Gradient -->
    <path
        android:pathData="M 54,20 L 57.5,27 L 65,28 L 59.5,33 L 61,40 L 54,36.5 L 47,40 L 48.5,33 L 43,28 L 50.5,27 Z"
        android:fillType="nonZero">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="43"
                android:startY="20"
                android:endX="65"
                android:endY="40"
                android:type="linear">
                <item android:offset="0" android:color="#fbbf24" />
                <item android:offset="1" android:color="#f59e0b" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
